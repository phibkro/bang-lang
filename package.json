{
  "name": "bang-lang",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "test": "vitest",
    "check": "vp exec tsc --noEmit -p packages/core/tsconfig.json && vp exec tsc --noEmit -p packages/compiler/tsconfig.json && vp exec tsc --noEmit -p packages/cli/tsconfig.json && vp run lint",
    "lint": "eslint packages/core/src/ packages/compiler/src/ packages/cli/src/ --fix"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.83.1",
    "bun-types": "^1.3.11",
    "eslint": "^10.1.0",
    "eslint-plugin-functional": "^9.0.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite-plus": "^0.1.14",
    "vitest": "^3"
  },
  "packageManager": "pnpm@10.33.0"
}
